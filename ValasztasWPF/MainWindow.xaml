<Window x:Class="ValasztasWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Választási Adatok" Height="600" Width="1000"
        Loaded="Window_Loaded">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Fájl">
                <MenuItem Header="Megnyitás" Click="MenuMegnyitas_Click" />
                <Separator />
                <MenuItem Header="Kilépés" Click="MenuKilepes_Click" />
            </MenuItem>
        </Menu>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Kész" />
            </StatusBarItem>
        </StatusBar>
        <DataGrid x:Name="EredmenyGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F0F8FF"
                  GridLinesVisibility="Horizontal"
                  Margin="5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Év" Binding="{Binding Ev}" Width="60" />
                <DataGridTextColumn Header="Megye" Binding="{Binding MegyeNev}" Width="150" />
                <DataGridTextColumn Header="Párt neve" Binding="{Binding PartNev}" Width="200" />
                <DataGridTextColumn Header="Rövidítés" Binding="{Binding Rovidites}" Width="90" />
                <DataGridTextColumn Header="Szavazatok" Binding="{Binding Szavazatok, StringFormat=N0}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Mandátumok" Binding="{Binding Mandatumok}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Szavazatarány %" Binding="{Binding SzavazataranySzazalek, StringFormat=F2}" Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
